# Caddyfile for local TLS and production reverse proxy
{$DOMAIN_NAME:localhost} {
    handle /api/* {
        reverse_proxy api:8000
    }
    handle /docs* {
        reverse_proxy api:8000
    }
    handle /openapi.json {
        reverse_proxy api:8000
    }
    handle /* {
        reverse_proxy frontend:3000
    }
}
