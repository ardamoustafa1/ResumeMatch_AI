# Application
APP_ENV=development
API_PORT=8000
DEBUG=True
SECRET_KEY=replace-with-at-least-32-random-characters
ALLOWED_ORIGINS=http://localhost:3000
SECURE_COOKIES=false
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14
FRONTEND_URL=http://localhost:3000
EMAIL_VERIFICATION_REQUIRED=false

# Optional SMTP (required when verification is enabled in production)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_STARTTLS=true

# Database (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=resumematch_ai
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
DB_MIN_CONNECTIONS=10
DB_MAX_CONNECTIONS=50

# Redis / Broker
# Used for Celery broker, Celery backend, and FastAPI caching
REDIS_URL=redis://redis:6379/0

# --- AI Configuration ---
# To use Groq (Recommended for speed and quality):
# GROQ_API_KEY=your_real_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# To use Local Ollama (Default, fully private):
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3:8b

# Notifications
TELEGRAM_BOT_TOKEN=placeholder

# Upload safety
MAX_UPLOAD_BYTES=10485760
MAX_PDF_PAGES=25
MAX_IMAGE_PIXELS=25000000
